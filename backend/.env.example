APP_NAME=MedCore HMS
APP_VERSION=0.1.0
# Frontend origin allowed to call this API (Vite dev server)
CORS_ORIGINS=http://localhost:5173
# PostgreSQL connection - the Docker Postgres (see infra/) listens on 5433,
# not 5432, because this machine's native Postgres already uses 5432.
DATABASE_URL=postgresql+psycopg://hms:CHANGE_ME@localhost:5433/hms

# Auth - generate a real random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_random_64char_hex_string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=600

# Outbound email (Brevo free-tier transactional API - brevo.com)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@yourdomain.example
BREVO_SENDER_NAME=MedCore HMS

# Used to build password-reset / email-verification links
FRONTEND_BASE_URL=http://localhost:5173
