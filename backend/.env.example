APP_NAME=MedCore HMS
APP_VERSION=0.1.0
# Frontend origin allowed to call this API (Vite dev server)
CORS_ORIGINS=http://localhost:5173
# PostgreSQL connection - the Docker Postgres (see infra/) listens on 5433,
# not 5432, because this machine's native Postgres already uses 5432.
DATABASE_URL=postgresql+psycopg://hms:CHANGE_ME@localhost:5433/hms
