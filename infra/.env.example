# Copy this file to .env and adjust if needed. .env itself is gitignored.
POSTGRES_USER=hms
POSTGRES_PASSWORD=changeme_dev_password
POSTGRES_DB=hms
# Host port 5433 (not 5432) because this machine already has a native
# PostgreSQL install listening on 5432 - Docker Postgres avoids it here.
POSTGRES_PORT=5433
VALKEY_PORT=6379
